# --- Database (single Postgres, per-service schema via ?schema=) ---
# Host port is 55432 to avoid clashing with a local Postgres on 5432.
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/rocket

# --- Redis (GEO matching, Pub/Sub, presence TTL) ---
# Host port is 56379 to avoid clashing with a local Redis on 6379.
REDIS_URL=redis://localhost:56379

# --- Docker host port mappings (change these if the ports are taken locally;
#     keep DATABASE_URL / REDIS_URL above in sync) ---
POSTGRES_HOST_PORT=55432
REDIS_HOST_PORT=56379

# --- Auth ---
JWT_SECRET=dev-super-secret-change-me
JWT_EXPIRES_IN=1d

# --- Traefik edge proxy (single entry point: routing / LB / CORS) ---
TRAEFIK_HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8080

# --- Service ports ---
USER_SERVICE_PORT=3001
DRIVER_SERVICE_PORT=3002
TRIP_SERVICE_PORT=3003
REALTIME_SERVICE_PORT=3004

# --- Frontend dev ports ---
WEB_PASSENGER_PORT=5173
WEB_DRIVER_PORT=5174
