# One Postgres DB `rocket`, per-service schema via ?schema=
# Host Postgres port is 55432 (5432 is taken locally) — keep in sync with root .env
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/rocket?schema=user

# --- Auth (user-service issues JWTs; realtime-service verifies — secrets must match) ---
JWT_SECRET=dev-super-secret-change-me
JWT_EXPIRES_IN=1d

USER_SERVICE_PORT=3001
