{
  "name": "@rocket/user-service",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "files": ["dist", "prisma", "prisma.config.ts"],
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@rocket/contracts": "workspace:*",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.5.0",
    "nestjs-zod": "^4.3.1",
    "pg": "^8.16.3",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@rocket/tsconfig": "workspace:*",
    "@swc/core": "^1.15.33",
    "@testcontainers/postgresql": "^12.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.18.0",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.7",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.7"
  }
}
