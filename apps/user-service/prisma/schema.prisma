datasource db {
  provider = "postgresql"
  schemas  = ["user"]
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         String
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("users")
  @@schema("user")
}
