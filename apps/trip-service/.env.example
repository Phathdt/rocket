# One Postgres DB `rocket`, per-service schema via ?schema=
# Host Postgres port is 55432 (5432 is taken locally) — keep in sync with root .env
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/rocket?schema=trip

# Redis: Pub/Sub trip events (realtime-service subscribes)
# Host Redis port is 56379 (6379 is taken locally) — keep in sync with root .env
REDIS_URL=redis://localhost:56379

# gRPC client target — trip-service → driver-service (docker compose: driver-service:50051)
DRIVER_GRPC_URL=localhost:50051

TRIP_SERVICE_PORT=3003
