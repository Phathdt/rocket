generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Driver {
  id           String   @id @default(uuid())
  userId       String   @unique
  name         String
  vehiclePlate String
  vehicleModel String
  status       String   @default("OFFLINE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("drivers")
}
