# One Postgres DB `rocket`, per-service schema via ?schema=
# Host Postgres port is 55432 (5432 is taken locally) — keep in sync with root .env
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/rocket?schema=driver

# Redis: GEO matching + presence TTL + Pub/Sub events
# Host Redis port is 56379 (6379 is taken locally) — keep in sync with root .env
REDIS_URL=redis://localhost:56379

# gRPC server address (trip-service dials this; inside docker compose: 0.0.0.0:50051)
DRIVER_GRPC_URL=0.0.0.0:50051

DRIVER_SERVICE_PORT=3002
