{
  "name": "rocket",
  "version": "0.0.0",
  "private": true,
  "description": "Ride-hailing microservices demo (Grab-like)",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "pnpm --filter @rocket/user-service db:seed && pnpm --filter @rocket/driver-service db:seed",
    "db:seed:online": "ts-node scripts/seed-drivers-online.ts",
    "sim": "pnpm --filter @rocket/driver-simulator start --",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "@types/pg": "^8.16.0",
    "lefthook": "^2.1.8",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "pg": "^8.16.3",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.30.3"
}
